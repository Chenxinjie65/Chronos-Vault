# Copy to `.env` and fill in the values for your target chain.
#
# Variables consumed by the deployment script itself:
TREASURY=0x0000000000000000000000000000000000000000
EXISTING_TOKEN=0x0000000000000000000000000000000000000000
DEPLOY_MOCK=true
MOCK_NAME=Chronos Mock
MOCK_SYMBOL=CMOCK
MOCK_INITIAL_SUPPLY=1000000000000000000000000

# Variables typically consumed by the Foundry CLI when broadcasting:
PRIVATE_KEY=

# Example RPC endpoints. You only need to fill the networks you actually use.
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=

# Example explorer API keys for Etherscan-compatible verification.
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
ARBISCAN_API_KEY=

# Example Blockscout-style verification settings.
BLOCKSCOUT_API_KEY=
BLOCKSCOUT_VERIFIER_URL=
